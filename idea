 Phase 1 — Core CLI & Vault Indexing

 Goal: A working CLI that can initialize a vault, scan Markdown files, parse wikilinks/tags/frontmatter, store everything in a SQLite index with FTS5, and report vault status.

 1.1 Project scaffolding

 - cargo init openidiom
 - Set up Cargo.toml with dependencies listed above
 - Set up src/main.rs with clap derive-based CLI skeleton
 - Define all top-level subcommands (even if unimplemented — use todo!())

 1.2 Vault initialization (oi init)

 - Create .openidiom/ directory in current folder
 - Create .openidiom/config.toml with defaults:
 [vault]
 name = "my-vault"
 daily_folder = "daily"
 daily_format = "%Y-%m-%d"
 ignore = [".openidiom", ".git", "node_modules", ".obsidian"]

 [ai]
 provider = "claude"  # claude | openai | ollama
 # API keys read from env: ANTHROPIC_API_KEY, OPENAI_API_KEY
 # ollama_url = "http://localhost:11434"
 embedding_provider = "openai"
 embedding_model = "text-embedding-3-small"
 - Create .openidiom/index.db (empty SQLite database with schema applied)
 - Validate config on creation (see Config Validation section)
 - Print confirmation

 1.3 Config validation (core/vault.rs)

 All config loading must validate:
 - Required fields present and non-empty
 - provider must be one of: claude, openai, ollama
 - embedding_provider must be one of: openai, ollama
 - daily_format must be a valid chrono format string
 - ignore patterns must be valid
 - Unknown keys trigger a warning (not error) — forward compatibility
 - On validation failure: clear error message with the specific field, expected values,
   and a suggestion. Exit code 2.
 - Example: "Invalid provider 'chatgpt' in config.toml. Valid options: claude, openai, ollama"

 1.4 Markdown parser (core/parser.rs)

 Parser pipeline:
 1. gray_matter: extract YAML frontmatter → serde_yml::Value
 2. regex: extract wikilinks [[target]] and [[target|alias]]
 3. regex: extract tags #tag and #tag/subtag (from body; also from frontmatter 'tags' field)
 4. pulldown-cmark: extract headings (H1-H6) with level info
 5. Word count from body text

 Return a ParsedNote struct:
 pub struct ParsedNote {
     pub path: PathBuf,
     pub title: String,          // filename without .md, or frontmatter title
     pub frontmatter: Option<serde_yml::Value>,
     pub wikilinks: Vec<WikiLink>,
     pub tags: Vec<String>,
     pub headings: Vec<Heading>,
     pub word_count: usize,
     pub raw_content: String,    // body without frontmatter
 }

 pub struct WikiLink {
     pub target: String,        // the note being linked to
     pub alias: Option<String>, // display text
     pub line: usize,
 }

 pub struct Heading {
     pub text: String,
     pub level: u8,             // 1-6
     pub line: usize,
 }

 1.5 SQLite schema (db/schema.rs)

 CREATE TABLE notes (
     id INTEGER PRIMARY KEY,
     path TEXT UNIQUE NOT NULL,
     title TEXT NOT NULL,
     word_count INTEGER,
     frontmatter_json TEXT,     -- frontmatter stored as JSON
     content_hash TEXT,         -- SHA-256 for incremental re-indexing
     indexed_at TEXT NOT NULL
 );

 CREATE TABLE links (
     id INTEGER PRIMARY KEY,
     source_id INTEGER REFERENCES notes(id) ON DELETE CASCADE,
     target_title TEXT NOT NULL,
     target_id INTEGER REFERENCES notes(id) ON DELETE SET NULL,
     alias TEXT,
     line INTEGER
 );

 CREATE TABLE tags (
     id INTEGER PRIMARY KEY,
     note_id INTEGER REFERENCES notes(id) ON DELETE CASCADE,
     tag TEXT NOT NULL
 );

 CREATE TABLE headings (
     id INTEGER PRIMARY KEY,
     note_id INTEGER REFERENCES notes(id) ON DELETE CASCADE,
     text TEXT NOT NULL,
     level INTEGER NOT NULL,
     line INTEGER
 );

 -- FTS5 full-text search index
 CREATE VIRTUAL TABLE notes_fts USING fts5(
     title,
     content,
     content='notes',
     content_rowid='id',
     tokenize='porter unicode61'
 );

 -- Triggers to keep FTS5 in sync
 CREATE TRIGGER notes_fts_insert AFTER INSERT ON notes BEGIN
     INSERT INTO notes_fts(rowid, title, content)
     VALUES (new.id, new.title, '');
 END;
 -- Note: content column populated separately after indexing body text
 -- Full trigger set for UPDATE and DELETE included in implementation

 -- For AI phase (Phase 3)
 CREATE TABLE embeddings (
     id INTEGER PRIMARY KEY,
     note_id INTEGER REFERENCES notes(id) ON DELETE CASCADE,
     chunk_index INTEGER,
     start_byte INTEGER NOT NULL,   -- byte offset into file
     end_byte INTEGER NOT NULL,     -- byte offset into file
     preview TEXT,                  -- first 200 chars for display
     embedding BLOB,               -- f32 vector stored as bytes
     model TEXT
 );

 CREATE INDEX idx_tags_tag ON tags(tag);
 CREATE INDEX idx_links_source ON links(source_id);
 CREATE INDEX idx_links_target ON links(target_id);
 CREATE INDEX idx_notes_title ON notes(title);
 CREATE INDEX idx_embeddings_note ON embeddings(note_id);

 1.6 Indexer (core/index.rs)

 - Walk vault directory using walkdir, respecting ignore patterns from config
 - For each .md file:
   - Compute content hash (SHA-256 of file contents)
   - Skip if hash matches existing DB entry (incremental indexing)
   - Parse with core/parser.rs
   - Upsert into notes, links, tags, headings tables
   - Insert body text into notes_fts for full-text search
 - After all files indexed, run link resolution (core/link_resolver.rs):
   - Build title→path lookup (case-insensitive, handles duplicates)
   - Resolve links.target_id using Obsidian-compatible rules
   - Log warnings for ambiguous resolutions
 - Print summary: Indexed 142 notes, 387 links, 95 tags (12 new, 3 updated)

 1.7 oi index command

 - Load vault config from .openidiom/config.toml (with validation)
 - Run indexer
 - Flag: --force to re-index everything (ignore content hashes)
 - Flag: --stats to print detailed stats

 1.8 oi status command (cli/status.rs)

 oi status
 # Output:
 # Vault: my-vault (/home/user/notes)
 # Notes: 142 | Links: 387 | Tags: 95 unique
 # Last indexed: 2026-04-05 14:23:01 (2 hours ago)
 # Stale: 3 notes modified since last index
